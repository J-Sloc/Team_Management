generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String              @id @default(cuid())
  email                     String              @unique
  passwordHash              String
  role                      UserRole
  teams                     String[] // Array of team IDs (supports multiple teams for coaches)
  athletes                  Athlete[]
  createdWorkoutTemplates   WorkoutTemplate[]
  createdWorkoutInstances   WorkoutInstance[]
  createdMeetEntries        MeetEntry[]
  journals                  AthleteJournal[]
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  notes                     Note[]
  userSettings              UserSettings?
  integrationRuns           IntegrationRun[]

  @@map("users")
}

model Team {
  id               String             @id @default(cuid())
  name             String
  sport            Sport
  institutionId    String?
  seasonId         String?
  institution      Institution?       @relation(fields: [institutionId], references: [id])
  season           Season?            @relation(fields: [seasonId], references: [id])
  athletes         Athlete[]
  events           Event[]
  workoutTemplates WorkoutTemplate[]
  meetEntries      MeetEntry[]
  performanceSnapshots AthletePerformanceSnapshot[]
  eventPerformanceTrends EventPerformanceTrend[]
  workoutAnalyticsSnapshots WorkoutAnalyticsSnapshot[]
  createdAt        DateTime           @default(now())

  @@map("teams")
}

model Institution {
  id          String   @id @default(cuid())
  name        String
  type        String?  // "HIGH_SCHOOL", "COLLEGE", "CLUB", etc.
  address     String?
  teams       Team[]
  seasons     Season[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("institutions")
}

model Season {
  id             String      @id @default(cuid())
  institutionId  String
  name           String      // "2024-2025", "Fall 2024", etc.
  startDate      DateTime
  endDate        DateTime
  sport          Sport
  institution    Institution @relation(fields: [institutionId], references: [id])
  teams          Team[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([institutionId, name, sport])
  @@index([institutionId, sport])
  @@map("seasons")
}

model Athlete {
  id                   String            @id @default(cuid())
  teamId               String
  name                 String
  jerseyNumber         Int?
  height               Float?
  weight               Float?
  classYear            String?
  sport                String?
  userId               String?
  user                 User?           @relation(fields: [userId], references: [id])
  events               String[]
  eventRecords        Json? // New: { "100m": { personalBest: 10.5, historical: [10.7, 10.6] } }
  gpa                  Float?
  academicStanding     AcademicStanding?
  eligibilityYearsLeft Float?
  recruitingStatus    String?
  contactInfo          String?
  transferProbability  Float?
  medicalStatus        MedicalStatus?
  complianceStatus     ComplianceStatus?
  riskFlag             RiskFlag?
  team                 Team              @relation(fields: [teamId], references: [id])
  academicRecords      AcademicRecord[]
  healthRecords        HealthRecord[]
  notes                Note[]
  calendarEntries      Event[]
  workoutInstances     WorkoutInstance[]
  eventRankings        EventRanking[]
  personalRecords      PersonalRecord[]
  meetEntries          MeetEntry[]
  journals             AthleteJournal[]
  performanceSnapshot  AthletePerformanceSnapshot?
  eventPerformanceTrends EventPerformanceTrend[]
  workoutAnalyticsSnapshot WorkoutAnalyticsSnapshot?

  @@index([teamId])
  @@map("athletes")
}

model AcademicRecord {
  id                String            @id @default(cuid())
  athleteId         String
  semester          String
  finalScore        Float?
  termGpa           Float?
  academicStanding  AcademicStanding?
  complianceStatus  ComplianceStatus?
  attendancePercent Float?
  tutoringHours     Float?
  advisorNotes      String?
  createdAt         DateTime          @default(now())
  athlete           Athlete           @relation(fields: [athleteId], references: [id])

  @@index([athleteId])
  @@index([semester, academicStanding])
  @@map("academic_records")
}

model HealthRecord {
  id                    String         @id @default(cuid())
  athleteId             String
  injuryType            String?
  injuryDate            DateTime?
  status                MedicalStatus?
  rehabSessions         Int?
  appointmentAttendance Float?
  notes                 String?
  createdAt             DateTime       @default(now())
  athlete               Athlete        @relation(fields: [athleteId], references: [id])

  @@index([athleteId])
  @@map("health_records")
}

model Event {
  id              String     @id @default(cuid())
  teamId          String
  athleteId       String?
  type            EventType
  title           String
  description     String?
  startTime       DateTime
  endTime         DateTime
  location        String?
  opponent        String?
  group           EventGroup
  createdByUserId String?
  createdAt       DateTime   @default(now())
  team            Team       @relation(fields: [teamId], references: [id])
  athlete         Athlete?   @relation(fields: [athleteId], references: [id])

  @@index([teamId, startTime])
  @@index([athleteId, startTime])
  @@map("events")
}

model Note {
  id        String       @id @default(cuid())
  athleteId String?
  userId    String
  category  NoteCategory
  body      String
  createdAt DateTime     @default(now())
  athlete   Athlete?     @relation(fields: [athleteId], references: [id])
  user      User         @relation(fields: [userId], references: [id])

  @@index([athleteId])
  @@map("notes")
}

model WorkoutTemplate {
  id             String          @id @default(cuid())
  teamId         String
  createdByUserId String?
  name           String
  description    String?
  sport          Sport
  params         Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  team           Team            @relation(fields: [teamId], references: [id])
  createdBy      User?           @relation(fields: [createdByUserId], references: [id])
  metrics        WorkoutMetric[]
  instances      WorkoutInstance[]

  @@index([teamId, sport])
  @@map("workout_templates")
}

model WorkoutMetric {
  id                String          @id @default(cuid())
  workoutTemplateId String
  name              String
  targetValue       Float?
  unit              MeasurementUnit?
  params            Json?
  createdAt         DateTime        @default(now())
  workoutTemplate   WorkoutTemplate @relation(fields: [workoutTemplateId], references: [id])

  @@index([workoutTemplateId])
  @@map("workout_metrics")
}

model WorkoutInstance {
  id                String          @id @default(cuid())
  workoutTemplateId String?
  athleteId         String
  createdByUserId   String?
  performedAt       DateTime        @default(now())
  notes             String?
  results           Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  workoutTemplate   WorkoutTemplate? @relation(fields: [workoutTemplateId], references: [id])
  athlete           Athlete         @relation(fields: [athleteId], references: [id])
  createdBy         User?           @relation(fields: [createdByUserId], references: [id])

  @@index([athleteId])
  @@index([workoutTemplateId])
  @@map("workout_instances")
}

model RankingSource {
  id          String        @id @default(cuid())
  name        String
  type        String?
  details     Json?
  createdAt   DateTime      @default(now())
  eventRankings EventRanking[]

  @@map("ranking_sources")
}

model EventRanking {
  id              String        @id @default(cuid())
  athleteId       String
  rankingSourceId String
  eventName       String
  rank            Int
  region          String?
  score           Float?
  recordedAt      DateTime      @default(now())
  athlete         Athlete       @relation(fields: [athleteId], references: [id])
  rankingSource   RankingSource @relation(fields: [rankingSourceId], references: [id])

  @@index([athleteId])
  @@index([rankingSourceId])
  @@map("event_rankings")
}

model PersonalRecord {
  id           String          @id @default(cuid())
  athleteId    String
  eventName    String
  result       Float
  unit         MeasurementUnit
  recordedAt   DateTime        @default(now())
  notes        String?
  athlete      Athlete         @relation(fields: [athleteId], references: [id])

  @@index([athleteId])
  @@map("personal_records")
}

model MeetEntry {
  id              String        @id @default(cuid())
  athleteId       String
  teamId          String
  eventName       String
  heat            String?
  lane            String?
  status          String?
  importedFrom    String?
  createdByUserId String?
  createdAt       DateTime      @default(now())
  athlete         Athlete       @relation(fields: [athleteId], references: [id])
  team            Team          @relation(fields: [teamId], references: [id])
  createdBy       User?          @relation(fields: [createdByUserId], references: [id])

  @@index([teamId, athleteId])
  @@map("meet_entries")
}

model AthleteJournal {
  id         String    @id @default(cuid())
  athleteId  String
  authorId   String
  authorRole UserRole
  title      String?
  body       String
  visibility String?   @default("PRIVATE")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  athlete    Athlete   @relation(fields: [athleteId], references: [id])
  author     User      @relation(fields: [authorId], references: [id])

  @@index([athleteId, authorId])
  @@map("athlete_journals")
}

model UserSettings {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  gpaThresholds  Json?   // e.g., { ineligible: 2.0, atRisk: 2.5 }
  medicalStatuses Json?  // e.g., { attendanceThreshold: 80 }
  defaultFilters Json?   // e.g., { classYear: ["Senior"], riskFlag: ["HIGH"] }
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("user_settings")
}

model AthletePerformanceSnapshot {
  id             String   @id @default(cuid())
  athleteId      String   @unique
  teamId         String
  trainingStatus String
  readinessScore Float?
  readinessLabel String?
  riskLevel      RiskFlag?
  lastWorkoutAt  DateTime?
  summaryJson    Json?
  aiSummary      String?
  refreshedAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  athlete        Athlete  @relation(fields: [athleteId], references: [id])
  team           Team     @relation(fields: [teamId], references: [id])

  @@index([teamId, refreshedAt])
  @@map("athlete_performance_snapshots")
}

model EventPerformanceTrend {
  id               String   @id @default(cuid())
  athleteId        String
  teamId           String
  eventName        String
  metricType       String
  baseline         Float?
  recentAverage    Float?
  latestValue      Float?
  latestRank       Int?
  recentDelta      Float?
  slope            Float?
  confidenceLabel  String
  sampleSize       Int      @default(0)
  summaryJson      Json?
  aiSummary        String?
  refreshedAt      DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  athlete          Athlete  @relation(fields: [athleteId], references: [id])
  team             Team     @relation(fields: [teamId], references: [id])

  @@unique([athleteId, eventName, metricType])
  @@index([teamId, eventName])
  @@map("event_performance_trends")
}

model WorkoutAnalyticsSnapshot {
  id                String   @id @default(cuid())
  athleteId         String   @unique
  teamId            String
  plannedMetricCount Int     @default(0)
  aboveTargetCount  Int      @default(0)
  onTargetCount     Int      @default(0)
  belowTargetCount  Int      @default(0)
  adherencePercent  Float?
  rolling7          Json?
  rolling14         Json?
  rolling30         Json?
  recentProgression Json?
  summaryJson       Json?
  aiSummary         String?
  refreshedAt       DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  athlete           Athlete  @relation(fields: [athleteId], references: [id])
  team              Team     @relation(fields: [teamId], references: [id])

  @@index([teamId, refreshedAt])
  @@map("workout_analytics_snapshots")
}

model IntegrationRun {
  id              String   @id @default(cuid())
  provider        String
  triggerType     String
  status          String
  startedAt       DateTime @default(now())
  finishedAt      DateTime?
  triggeredByUserId String?
  scopeJson       Json?
  resultSummary   Json?
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  triggeredBy     User?    @relation(fields: [triggeredByUserId], references: [id])

  @@index([provider, createdAt])
  @@map("integration_runs")
}

enum UserRole {
  AD
  COACH
  ATHLETE
}

enum AcademicStanding {
  GOOD
  NEUTRAL
  BAD
}

enum MedicalStatus {
  CLEARED
  LIMITED
  NOT_CLEARED
}

enum ComplianceStatus {
  COMPLIANT
  WARNING
  NON_COMPLIANT
}

enum RiskFlag {
  HIGH
  MODERATE
  LOW
  NONE
}

enum EventType {
  GAME
  PRACTICE
  MEETING
  MEDICAL
  ACADEMIC
  RECRUITING
}

enum EventGroup {
  TEAM
  PERSONAL
}

enum NoteCategory {
  ACADEMIC
  MEDICAL
  GENERAL
  SPORT_SPECIFIC
}

enum Sport {
  TRACK_AND_FIELD
  FOOTBALL
  SOCCER
  GENERAL
}

enum MeasurementUnit {
  METERS
  KILOMETERS
  YARDS
  SECONDS
  MINUTES
  HOURS
}
